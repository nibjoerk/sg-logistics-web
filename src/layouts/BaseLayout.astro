---
import "../styles/global.css";

const {
  title = "SG Logistics AS",
  description = "Transport, logistikk, fortolling og verdiøkende tjenester.",
} = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <slot />
  </body>
</html>