---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { articles } from "../../data/articles";

const categories = [...new Set(articles.map((article) => article.category))];

const getCategoryId = (category: string) =>
  category.toLowerCase().replaceAll(" ", "-").replaceAll("ø", "o").replaceAll("å", "a").replaceAll("æ", "ae");
---

<BaseLayout
  title="Kjekt å vite | SG Logistics AS"
  description="Nyttig informasjon om sjøfrakt, flyfrakt, veitransport, toll, dokumenter, pakking og forsikring."
>
  <Header />

  <main>
    <section class="section knowledge-page">
      <div class="container">
        <div class="section-header knowledge-header">
          <p class="eyebrow">Kjekt å vite</p>
          <h1>Nyttig logistikkunnskap samlet på ett sted</h1>
          <p class="section-intro">
            Her finner du praktiske forklaringer på container, sjøfrakt,
            flyfrakt, veitransport, toll, dokumenter, pakking og forsikring.
          </p>
        </div>

        <nav class="category-nav" aria-label="Kategorier">
          {categories.map((category) => (
            <a href={`#${getCategoryId(category)}`}>{category}</a>
          ))}
        </nav>

        <div class="knowledge-sections">
          {categories.map((category) => (
            <section id={getCategoryId(category)} class="knowledge-category">
              <div class="category-heading">
                <p class="eyebrow">{category}</p>
                <h2>{category}</h2>
              </div>

              <div class="article-grid">
                {articles
                  .filter((article) => article.category === category)
                  .map((article) => (
                    <article class="article-card card">
                      <h3>{article.title}</h3>
                      <p>{article.intro}</p>
                      <a href={article.href ?? article.path}>Les mer →</a>
                    </article>
                  ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .knowledge-page h1 {
    color: var(--black);
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    line-height: 1;
    letter-spacing: -0.05em;
    margin-bottom: 20px;
    max-width: 900px;
  }

  .knowledge-header {
    margin-bottom: 34px;
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 58px;
  }

  .category-nav a {
    background: white;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--dark);
    font-weight: 800;
    padding: 10px 15px;
  }

  .category-nav a:hover {
    color: var(--green);
    border-color: var(--green);
  }

  .knowledge-sections {
    display: grid;
    gap: 64px;
  }

  .knowledge-category {
    scroll-margin-top: 110px;
  }

  .category-heading {
    margin-bottom: 22px;
  }

  .category-heading h2 {
    color: var(--black);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin: 0;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .article-card {
    padding: 30px;
  }

  .article-card h3 {
    color: var(--black);
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .article-card p {
    color: var(--text);
    margin-bottom: 18px;
  }

  .article-card a {
    color: var(--green);
    font-weight: 900;
  }

  @media (max-width: 1000px) {
    .article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
