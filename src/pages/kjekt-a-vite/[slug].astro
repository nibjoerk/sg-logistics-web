---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import { articles } from "../../data/articles";

export function getStaticPaths() {
  return articles.map((article) => ({ params: { slug: article.slug }, props: { article } }));
}
const { article } = Astro.props;
---

<BaseLayout title={article.seoTitle} description={article.seoDescription}>
  <Header />
  <main>
    <article class="section article-page">
      <div class="container article-wrap">
        <p class="eyebrow">{article.category}</p>
        <h1>{article.title}</h1>
        <p class="intro">{article.intro}</p>
        <div class="article-body">
          {article.body.map((block) => (<section class="card"><h2>{block.heading}</h2><p>{block.text}</p></section>))}
        </div>
      </div>
    </article>
    <Contact />
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-page { background: var(--light); }
  .article-wrap { max-width: 840px; }
  .article-page h1 { color: var(--black); font-size: clamp(3rem, 5vw, 4.8rem); line-height: 1; letter-spacing: -0.05em; margin-bottom: 22px; }
  .intro { color: var(--text); font-size: 1.18rem; line-height: 1.75; margin-bottom: 44px; }
  .article-body { display: grid; gap: 20px; }
  .article-body section { padding: 30px; }
  .article-body h2 { color: var(--black); margin-bottom: 12px; }
  .article-body p { color: var(--text); }
</style>
