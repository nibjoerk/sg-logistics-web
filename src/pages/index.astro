---
import logo from "../assets/logo/logo_venstre_pms.svg";
import heroRoad from "../assets/images/hero-road.jpg";

import ase from "../assets/images/Employees/Åse Haram.jpg";
import cathrine from "../assets/images/Employees/Cathrine Lunheim.jpg";
import christian from "../assets/images/Employees/Christian Lunheim.jpg";
import geir from "../assets/images/Employees/Geir Bjørkavåg.jpg";
import harald from "../assets/images/Employees/Harald Larsen.jpg";
import hilde from "../assets/images/Employees/Hilde Solevågseide.jpg";
import lars from "../assets/images/Employees/Lars Ove Håhjem.jpg";
import mads from "../assets/images/Employees/Mads Nedregaard.jpg";
import martin from "../assets/images/Employees/Martin Gjerde.jpg";
import nathalie from "../assets/images/Employees/Nathalie Bratteng.jpg";
import nilsErik from "../assets/images/Employees/Nils Erik Bjørkedal.jpg";
import silje from "../assets/images/Employees/Silje Breivik.jpg";
import torgeir from "../assets/images/Employees/Torgeir Stene.jpg";
import trine from "../assets/images/Employees/Trine Nybø.jpg";
import trude from "../assets/images/Employees/Trude Fiskerstrand.jpg";

const employees = [
  { name: "Åse Haram", image: ase },
  { name: "Cathrine Lunheim", image: cathrine },
  { name: "Christian Lunheim", image: christian },
  { name: "Geir Bjørkavåg", image: geir },
  { name: "Harald Larsen", image: harald },
  { name: "Hilde Solevågseide", image: hilde },
  { name: "Lars Ove Håhjem", image: lars },
  { name: "Mads Nedregaard", image: mads },
  { name: "Martin Gjerde", image: martin },
  { name: "Nathalie Bratteng", image: nathalie },
  { name: "Nils Erik Bjørkedal", image: nilsErik },
  { name: "Silje Breivik", image: silje },
  { name: "Torgeir Stene", image: torgeir },
  { name: "Trine Nybø", image: trine },
  { name: "Trude Fiskerstrand", image: trude },
];
---

<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SG Logistics AS</title>
  </head>

  <body>
    <header class="header">
      <img src={logo.src} alt="SG Logistics" class="logo" />

      <nav>
        <a href="#tjenester">Tjenester</a>
        <a href="#om-oss">Om oss</a>
        <a href="#ansatte">Ansatte</a>
        <a href="#kontakt">Kontakt</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-text">
          <p class="eyebrow">Logistikk · Transport · Fortolling</p>
          <h1>Logistikkløsninger som får varene trygt frem</h1>
          <p>
            SG Logistics hjelper norske bedrifter med effektive transport- og
            logistikkløsninger i Norge og internasjonalt.
          </p>

          <div class="buttons">
            <a class="button primary" href="#kontakt">Kontakt oss</a>
            <a class="button secondary" href="#tjenester">Se tjenester</a>
          </div>
        </div>

        <img src={heroRoad.src} alt="Transport" class="hero-image" />
      </section>

      <section id="tjenester" class="section light">
        <p class="eyebrow">Hva vi gjør</p>
        <h2>Transport og logistikk fra A til Å</h2>
        <p class="section-intro">
          Vi kombinerer erfaring, personlig oppfølging og praktisk gjennomføringsevne
          for å finne gode løsninger for hver enkelt kunde.
        </p>

        <div class="service-grid">
          <article>
            <h3>Sjøfrakt</h3>
            <p>Kostnadseffektiv transport av gods internasjonalt, med fleksible løsninger for import og eksport.</p>
          </article>
          <article>
            <h3>Flyfrakt</h3>
            <p>Rask transport når tid er avgjørende, med oppfølging fra booking til levering.</p>
          </article>
          <article>
            <h3>Biltransport</h3>
            <p>Smidige veitransportløsninger i Norge og Europa, tilpasset kundens behov.</p>
          </article>
          <article>
            <h3>Fortolling</h3>
            <p>Hjelp med dokumentasjon, tollbehandling og praktisk håndtering av import og eksport.</p>
          </article>
        </div>
      </section>

      <section id="om-oss" class="section about">
        <div>
          <p class="eyebrow">Om SG Logistics</p>
          <h2>Personlig oppfølging og høy fagkompetanse</h2>
        </div>

        <div>
          <p>
            SG Logistics er en logistikkpartner for bedrifter som trenger
            forutsigbarhet, god kommunikasjon og praktiske løsninger.
          </p>
          <p>
            Vi legger vekt på tett kundedialog, raske avklaringer og trygg
            gjennomføring — enten det gjelder import, eksport, transport eller
            fortolling.
          </p>
        </div>
      </section>

      <section id="ansatte" class="section">
        <p class="eyebrow">Vårt team</p>
        <h2>Menneskene bak SG Logistics</h2>
        <p class="section-intro">
          Hos oss møter du erfarne fagfolk som følger opp transporten fra første
          forespørsel til varene er levert.
        </p>

        <div class="employee-grid">
          {
            employees.map((employee) => (
              <article class="employee-card">
                <div class="employee-image-wrap">
                  <img src={employee.image.src} alt={employee.name} />
                </div>
                <h3>{employee.name}</h3>
              </article>
            ))
          }
        </div>
      </section>

      <section id="kontakt" class="contact">
        <p class="eyebrow">Kontakt</p>
        <h2>Trenger du hjelp med transport eller logistikk?</h2>
        <p>Send oss en forespørsel, så finner vi en god løsning for ditt behov.</p>
        <a class="button primary" href="mailto:post@sglogistics.no">post@sglogistics.no</a>
      </section>
    </main>

    <footer class="footer">
      <img src={logo.src} alt="SG Logistics" />
      <p>© 2026 SG Logistics AS</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --green: #009639;
    --grey: #a2aaad;
    --dark-grey: #333f48;
    --black: #000000;
    --process-black: #2b2926;
    --white: #ffffff;
    --light: #f7f8f8;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: "Neo Sans", "Segoe UI", Arial, sans-serif;
    color: var(--dark-grey);
    background: var(--white);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .header {
    height: 82px;
    padding: 0 7vw;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: white;
    border-bottom: 1px solid rgba(51, 63, 72, 0.12);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .logo {
    height: 46px;
    width: auto;
  }

  nav {
    display: flex;
    gap: 34px;
    font-weight: 600;
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--green);
  }

  .hero {
    padding: 78px 7vw 70px;
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 70px;
    align-items: center;
    background: white;
  }

  .hero-text {
    max-width: 610px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 800;
    font-size: 0.78rem;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: -0.065em;
    color: var(--process-black);
    margin-bottom: 28px;
  }

  h2 {
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--process-black);
    margin-bottom: 18px;
  }

  h3 {
    color: var(--process-black);
    margin-bottom: 12px;
  }

  p {
    line-height: 1.7;
  }

  .hero-text p:not(.eyebrow),
  .section-intro,
  .about p,
  .service-grid p {
    color: rgba(51, 63, 72, 0.78);
  }

  .hero-text p:not(.eyebrow) {
    font-size: 1.18rem;
    margin-bottom: 32px;
  }

  .buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 25px;
    border-radius: 12px;
    font-weight: 800;
  }

  .button.primary {
    background: var(--green);
    color: white;
  }

  .button.secondary {
    border: 1px solid rgba(51, 63, 72, 0.24);
    background: white;
  }

  .hero-image {
    width: 100%;
    height: 520px;
    object-fit: cover;
    border-radius: 20px;
    box-shadow: 0 22px 60px rgba(43, 41, 38, 0.14);
  }

  .section {
    padding: 88px 7vw;
  }

  .light {
    background: var(--light);
  }

  .section-intro {
    max-width: 720px;
    margin-bottom: 44px;
    font-size: 1.08rem;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }

  .service-grid article {
    background: white;
    border: 1px solid rgba(51, 63, 72, 0.12);
    border-radius: 16px;
    padding: 32px;
    min-height: 220px;
  }

  .service-grid article::before {
    content: "";
    display: block;
    width: 42px;
    height: 5px;
    border-radius: 999px;
    background: var(--green);
    margin-bottom: 26px;
  }

  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    background: #eef1f2;
  }

  .about p {
    font-size: 1.12rem;
  }

  .employee-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 22px;
  }

  .employee-card {
    background: white;
    border: 1px solid rgba(51, 63, 72, 0.12);
    border-radius: 16px;
    padding: 14px;
    box-shadow: 0 10px 26px rgba(43, 41, 38, 0.05);
  }

  .employee-image-wrap {
    height: 210px;
    background: var(--light);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .employee-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
  }

  .employee-card h3 {
    font-size: 0.96rem;
    margin: 14px 4px 4px;
  }

  .contact {
    padding: 90px 7vw;
    text-align: center;
    background:
      radial-gradient(circle at center top, rgba(0, 150, 57, 0.22), transparent 34%),
      var(--process-black);
    color: white;
  }

  .contact h2 {
    color: white;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .contact p {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 30px;
  }

  .footer {
    padding: 36px 7vw;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(51, 63, 72, 0.12);
  }

  .footer img {
    height: 40px;
    width: auto;
  }

  .footer p {
    margin: 0;
    color: rgba(51, 63, 72, 0.7);
  }

  @media (max-width: 1100px) {
    .hero,
    .about {
      grid-template-columns: 1fr;
    }

    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .employee-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-image {
      height: 430px;
    }
  }

  @media (max-width: 700px) {
    .header {
      padding: 0 24px;
    }

    nav {
      display: none;
    }

    .hero,
    .section,
    .contact {
      padding-left: 24px;
      padding-right: 24px;
    }

    .service-grid,
    .employee-grid {
      grid-template-columns: 1fr;
    }

    .hero-image {
      height: 320px;
    }

    .footer {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>