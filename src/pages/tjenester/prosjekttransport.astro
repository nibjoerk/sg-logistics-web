---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServicePageHero from '../../components/ServicePageHero.astro';
import ContentSection from '../../components/ContentSection.astro';
---

<BaseLayout title="Prosjekttransport | SG Logistics" description="Prosjekttransport, OOG, breakbulk, tungt gods og multimodale spesialløsninger.">
  <ServicePageHero
    eyebrow="Prosjekttransport"
    title="Når godset krever mer enn en standardløsning."
    lead="Vi planlegger og koordinerer spesialtransporter for tungt, overdimensjonert eller krevende gods på vei, sjø og fly."
    variant="project"
  />

  <ContentSection eyebrow="Planlegging" title="Prosjektlast og spesialtransport">
    <p>Prosjekttransport krever kontroll på detaljer. Dimensjoner, vekt, løftepunkter, rutevalg, løyver, kraning, surring og dokumentasjon må planlegges riktig før transporten starter.</p>
    <p>Vi kan bistå med transport av maskiner, industriutstyr, båter, stålkonstruksjoner, produksjonsutstyr og annen last som ikke passer i ordinære transportløsninger.</p>
  </ContentSection>

  <ContentSection eyebrow="Gjennomføring" title="Én koordinator gjennom hele prosjektet">
    <p>Vi koordinerer relevante transportører, terminaler, rederier, surveyor, kranleverandører og mottakere. Målet er en trygg og forutsigbar gjennomføring med færrest mulig overraskelser.</p>
    <ul>
      <li>OOG og breakbulk cargo.</li>
      <li>Spesialtransporter på bil.</li>
      <li>Chartret båt eller fly ved behov.</li>
      <li>Kombinerte og multimodale transporter.</li>
      <li>Surveyor, lasting, lossing, kraning og lastsikring.</li>
      <li>Løyver og transportdokumentasjon.</li>
    </ul>
  </ContentSection>
</BaseLayout>
