---
import "../styles/footer.css";
import logo from "../assets/logo/logo_venstre_pms.svg";

const footerLinks = [
  { label: "Tjenester", href: "/#tjenester" },
  { label: "Om oss", href: "/#om-oss" },
  { label: "Ansatte", href: "/#ansatte" },
  { label: "Dokumenter", href: "/#dokumenter" },
  { label: "Kjekt å vite", href: "/kjekt-a-vite" },
  { label: "Kontakt", href: "/#kontakt" },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src={logo.src} alt="SG Logistics" />

      <p>
        Transport, logistikk, fortolling og verdiøkende tjenester – med
        personlig oppfølging fra Ålesund.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Bunnmeny">
      {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>

  <div class="container footer-bottom">
    <p>© {new Date().getFullYear()} SG Logistics AS</p>
    <p>Breivika Industriveg 63 · 6018 Ålesund</p>
  </div>
</footer>
