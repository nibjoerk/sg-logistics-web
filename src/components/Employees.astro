---
import "../styles/employees.css";
import { employees } from "../data/employees";

const cleanPhone = (phone: string) => phone.replace(/\s/g, "");
---

<section id="ansatte" class="section section-light employees">
  <div class="container">
    <div class="employees-top">
      <div class="section-header employees-header">
        <p class="eyebrow">Våre ansatte</p>
        <h2>Menneskene bak SG Logistics</h2>

        <p class="section-intro">
          Våre medarbeidere har lang erfaring innen transport, logistikk,
          fortolling og internasjonal handel. Ta gjerne kontakt direkte med
          den som kan hjelpe deg best.
        </p>
      </div>

      <a href="#kontakt" class="employees-contact">
        <span>Trenger du hjelp?</span>
        <strong>Kontakt oss →</strong>
      </a>
    </div>

    <div class="employee-grid">
      {
        employees.map((employee) => (
          <article class="employee-card">
            <div class="employee-image">
              <img
                src={employee.image.src}
                alt={employee.name}
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="employee-content">
              <p class="employee-department">{employee.department}</p>

              <h3>{employee.name}</h3>

              <p class="employee-title">{employee.title}</p>

              <div class="employee-links">
                <a href={`tel:${cleanPhone(employee.phone)}`}>
                  <span aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.2 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.33 1.77.62 2.6a2 2 0 0 1-.45 2.11L8 9.71a16 16 0 0 0 6.29 6.29l1.27-1.27a2 2 0 0 1 2.11-.45c.83.29 1.7.5 2.6.62A2 2 0 0 1 22 16.92Z" />
                    </svg>
                  </span>
                  {employee.phone}
                </a>

                <a href={`mailto:${employee.email}`}>
                  <span aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path d="M4 4h16v16H4z" />
                      <path d="m4 7 8 6 8-6" />
                    </svg>
                  </span>
                  {employee.email}
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
