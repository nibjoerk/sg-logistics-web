---
import { employees } from "../data/employees";
---

<section id="ansatte" class="section section-light">
  <div class="container">

    <div class="section-header">
      <p class="eyebrow">Våre ansatte</p>
      <h2>Menneskene bak SG Logistics</h2>

      <p class="section-intro">
        Våre medarbeidere har lang erfaring innen transport, logistikk,
        fortolling og internasjonal handel. Ta gjerne kontakt direkte med
        den som kan hjelpe deg best.
      </p>
    </div>

    <div class="employee-grid">
      {
          employees.map((employee) => (
          <article class="employee-card">

            <div class="employee-image">
                <img
                    src={employee.image.src}
                    alt={employee.name}
                    loading="lazy"
                />
            </div>

            <div class="employee-content">

              <h3>{employee.name}</h3>

              <p class="title">
                {employee.title}
              </p>

              <p class="department">
                {employee.department}
              </p>

              <a href={`tel:${employee.phone.replace(/\s/g, "")}`}>
                {employee.phone}
              </a>

              <a href={`mailto:${employee.email}`}>
                {employee.email}
              </a>

            </div>

          </article>
        ))
      }
    </div>

  </div>
</section>

<style>

.container{
    max-width:1200px;
    margin:auto;
}

.section{
    padding:90px 24px;
}

.section-light{
    background:#f6f7f8;
}

.section-header{
    max-width:720px;
    margin-bottom:45px;
}

.eyebrow{
    color:#009639;
    text-transform:uppercase;
    font-size:.75rem;
    font-weight:700;
    letter-spacing:.15em;
}

.section-intro{
    color:#666;
}

.employee-grid{

    display:grid;

    grid-template-columns:
        repeat(auto-fit,minmax(320px,1fr));

    gap:22px;

}

.employee-card{

    display:flex;

    gap:18px;

    background:white;

    border-radius:16px;

    padding:18px;

    box-shadow:
        0 3px 10px rgba(0,0,0,.05);

}

.employee-image{

    width:110px;
    height:140px;

    display:flex;

    align-items:flex-end;

    justify-content:center;

    background:#f5f5f5;

    border-radius:12px;

    overflow:hidden;

}

.employee-image img{

    width:100%;

    height:100%;

    object-fit:contain;

    object-position:bottom center;

}

.employee-content{

    display:flex;

    flex-direction:column;

    justify-content:center;

}

.employee-content h3{

    margin:0 0 6px;

    font-size:1.05rem;

}

.title{

    margin:0;

    color:#009639;

    font-weight:600;

}

.department{

    margin:4px 0 12px;

    color:#777;

    font-size:.9rem;

}

.employee-content a{

    color:#333F48;

    text-decoration:none;

    margin-bottom:4px;

}

.employee-content a:hover{

    color:#009639;

}

@media(max-width:700px){

.employee-card{
    flex-direction:column;
    align-items:center;
    text-align:center;
}

.employee-image{
    width:120px;
    height:150px;
}

.employee-image img{
    width:100%;
    height:100%;
    object-fit:contain;
    object-position:bottom center;
}

}

</style>