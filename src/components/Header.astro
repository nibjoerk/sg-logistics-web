---
import "../styles/header.css";
import logo from "../assets/logo/logo_venstre_pms.svg";

const navItems = [
  { label: "Tjenester", href: "#tjenester" },
  { label: "Om oss", href: "#om-oss" },
  { label: "Ansatte", href: "#ansatte" },
  { label: "Dokumenter", href: "#dokumenter" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="SG Logistics">
      <img src={logo.src} alt="SG Logistics" />
    </a>

    <nav class="main-nav" aria-label="Hovedmeny">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}

      <a href="#kontakt" class="nav-cta">Kontakt</a>
    </nav>
  </div>
</header>
