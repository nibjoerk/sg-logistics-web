---
import logo from "../assets/logo/logo_venstre_pms.svg";

const navItems = [
  { label: "Tjenester", href: "/#tjenester" },
  { label: "Kjekt å vite", href: "/kjekt-a-vite" },
  { label: "Om oss", href: "/#om-oss" },
  { label: "Ansatte", href: "/#ansatte" },
  { label: "Dokumenter", href: "/#dokumenter" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="SG Logistics">
      <img src={logo.src} alt="SG Logistics" />
    </a>

    <nav class="main-nav" aria-label="Hovedmeny">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}

      <a href="/#kontakt" class="nav-cta">Kontakt</a>
    </nav>
  </div>
</header>

<style>
  .site-header { height: 76px; background: rgba(255, 255, 255, 0.96); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; backdrop-filter: blur(12px); }
  .header-inner { height: 100%; display: flex; align-items: center; justify-content: space-between; }
  .brand img { height: 40px; width: auto; }
  .main-nav { display: flex; align-items: center; gap: 6px; font-size: 0.95rem; font-weight: 700; }
  .main-nav a { padding: 10px 14px; border-radius: 999px; color: var(--dark); }
  .main-nav a:hover { color: var(--green); background: var(--light); }
  .main-nav .nav-cta { margin-left: 6px; background: var(--green); color: white; padding-inline: 18px; }
  .main-nav .nav-cta:hover { background: var(--green-dark); color: white; }
  @media (max-width: 900px) { .main-nav { display: none; } .brand img { height: 36px; } }
</style>
