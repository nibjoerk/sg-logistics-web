---
import heroImage from "../assets/images/hero-road.jpg";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">Worldwide logistics · with a personal touch</p>

      <h1>
        Logistikkløsninger som får varene trygt frem.
      </h1>

      <p class="hero-text">
        SG Logistics hjelper norske bedrifter med transport, fortolling og
        komplette logistikkløsninger i Norge, Europa og resten av verden.
      </p>

      <div class="hero-actions">
        <a href="#kontakt" class="button button-primary">Kontakt oss</a>
        <a href="#tjenester" class="button button-secondary">Våre tjenester</a>
      </div>
    </div>

    <div class="hero-media">
      <img src={heroImage.src} alt="Transport på vei" />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, #ffffff 0%, #f7f8f8 100%);
    padding: 78px 0 92px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 520px) minmax(460px, 1fr);
    gap: 72px;
    align-items: center;
  }

  .hero-copy {
    max-width: 520px;
  }

  .hero h1 {
    color: var(--black);
    font-size: clamp(2.8rem, 4.1vw, 4.25rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 26px;
    text-wrap: balance;
  }

  .hero-text {
    max-width: 500px;
    color: var(--text);
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: 34px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-media {
    border-radius: 24px;
    overflow: hidden;
    background: var(--light);
    box-shadow: 0 24px 70px rgba(43, 41, 38, 0.13);
  }

  .hero-media img {
    width: 100%;
    height: 430px;
    object-fit: cover;
  }

  @media (max-width: 1050px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .hero-copy {
      max-width: 720px;
    }

    .hero-text {
      max-width: 620px;
    }

    .hero-media {
      order: -1;
    }

    .hero-media img {
      height: 360px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 42px 0 68px;
    }

    .hero h1 {
      font-size: clamp(2.35rem, 11vw, 3.1rem);
      line-height: 1.08;
    }

    .hero-media img {
      height: 280px;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .button {
      width: 100%;
    }
  }
</style>