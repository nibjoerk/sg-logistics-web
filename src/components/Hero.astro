---
import "../styles/hero.css";
import heroImage from "../assets/images/hero-road.jpg";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">Worldwide logistics · with a personal touch</p>

      <h1>Logistikk som skaper flyt i hele verdikjeden.</h1>

      <p class="hero-text">
        SG Logistics hjelper norske bedrifter med bilfrakt, flyfrakt,
        sjøfrakt, fortolling og komplette logistikkløsninger – trygt,
        effektivt og personlig.
      </p>

      <div class="hero-actions">
        <a href="#kontakt" class="button button-primary">Kontakt oss</a>
        <a href="#tjenester" class="button button-secondary">Se tjenester</a>
      </div>
    </div>

    <div class="hero-media">
      <img
        src={heroImage.src}
        alt="Lastebil på vei gjennom et landskap"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>
