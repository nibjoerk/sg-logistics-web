---
import "../styles/documents.css";
import { documents } from "../data/documents";

const documentLabels: Record<string, string> = {
  PDF: "Last ned",
  HTML: "Åpne i nettleser",
};

const documentSubtitles: Record<string, string> = {
  PDF: "Rapport",
  HTML: "Nettversjon",
};
---

<section id="dokumenter" class="section section-light documents">
  <div class="container">
    <div class="section-header documents-header">
      <p class="eyebrow">Dokumenter</p>

      <h2>Rapporter og styrende dokumenter</h2>

      <p class="section-intro">
        Her samler vi rapporter, retningslinjer og styrende dokumenter som er
        relevante for kunder, leverandører og samarbeidspartnere.
      </p>
    </div>

    <div class="document-grid">
      {
        documents.map((document) => (
          <article class="document-card">
            <div class="document-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M6 3h8l4 4v14H6z" />
                <path d="M14 3v5h4" />
                <path d="M9 13h6" />
                <path d="M9 17h6" />
              </svg>
            </div>

            <div class="document-content">
              <div class="document-meta">
                <span>{document.type}</span>
                <span>{documentSubtitles[document.type] ?? "Dokument"}</span>
              </div>

              <h3>{document.title}</h3>

              <p>{document.description}</p>
            </div>

            <a href={document.href} target="_blank" rel="noopener noreferrer" class="document-link">
              {documentLabels[document.type] ?? "Åpne dokument"}
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
