---
const { variant = "20-standard" } = Astro.props;

const isFlat = variant === "flat-rack";
const isOpen = variant === "open-top";
const isReefer = variant === "reefer";
const isLong = variant.includes("40") || isFlat || isReefer;
const isHigh = variant === "40-high-cube" || isReefer;
const lengthLabel = isLong ? "12 192 mm" : "6 058 mm";
const heightLabel = isHigh ? "2 896 mm" : isFlat ? "648 mm" : "2 591 mm";
const widthLabel = "2 438 mm";
const panelCount = isLong ? 20 : 11;
const markerId = `arrow-${variant}`;
---

<div class="dimension-sketch premium-sketch">
  <div class="sketch-block sketch-side">
    <strong>Sidevisning</strong>
    <svg viewBox="0 0 620 210" role="img" aria-label="Teknisk sidevisning av container">
      <defs>
        <marker id={markerId} markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto-start-reverse">
          <path d="M0 0 8 4 0 8Z" />
        </marker>
        <pattern id={`corr-${variant}`} width="18" height="10" patternUnits="userSpaceOnUse">
          <path d="M2 0v10M9 0v10M16 0v10" />
        </pattern>
      </defs>

      <line class="dim-line" x1="68" y1="28" x2="510" y2="28" marker-start={`url(#${markerId})`} marker-end={`url(#${markerId})`} />
      <text x="289" y="20" text-anchor="middle">{lengthLabel}</text>
      <line class="dim-ext" x1="72" y1="40" x2="72" y2="61" />
      <line class="dim-ext" x1="506" y1="40" x2="506" y2="61" />

      <g class="container-linework">
        {isFlat ? (
          <>
            <rect x="76" y="124" width="430" height="26" rx="2" />
            <rect x="82" y="88" width="30" height="62" rx="2" />
            <rect x="470" y="88" width="30" height="62" rx="2" />
            <line x1="118" y1="116" x2="464" y2="116" />
            <line x1="118" y1="132" x2="464" y2="132" />
            {Array.from({ length: 14 }).map((_, i) => <circle cx={140 + i * 23} cy="140" r="3" />)}
            {Array.from({ length: 9 }).map((_, i) => <line x1={144 + i * 35} y1="124" x2={126 + i * 35} y2="150" />)}
          </>
        ) : (
          <>
            <rect x="76" y="64" width="430" height={isHigh ? "112" : "98"} rx="2" />
            <rect x="84" y="72" width="414" height={isHigh ? "96" : "82"} rx="1" />
            <rect x="84" y="72" width="414" height={isHigh ? "96" : "82"} fill={`url(#corr-${variant})`} opacity=".55" />
            {Array.from({ length: panelCount }).map((_, i) => {
              const x = 96 + i * (388 / (panelCount - 1));
              return <line class="rib-major" x1={x} y1="72" x2={x} y2={isHigh ? "168" : "154"} />;
            })}
            <rect x="76" y={isHigh ? "174" : "160"} width="430" height="8" rx="1" />
            <rect x="82" y={isHigh ? "178" : "164"} width="34" height="10" />
            <rect x="466" y={isHigh ? "178" : "164"} width="34" height="10" />
            <rect x="76" y="64" width="18" height={isHigh ? "112" : "98"} />
            <rect x="488" y="64" width="18" height={isHigh ? "112" : "98"} />
            {isReefer && (
              <g class="reefer-unit-sketch">
                <rect x="438" y="82" width="48" height="62" rx="3" />
                <circle cx="462" cy="113" r="13" />
                <circle cx="462" cy="113" r="4" />
              </g>
            )}
            {isOpen && <path class="open-top-sketch" d="M76 58H506M92 68h396" />}
          </>
        )}
      </g>

      <line class="dim-line" x1="548" y1={isFlat ? "88" : "64"} x2="548" y2={isFlat ? "150" : isHigh ? "182" : "168"} marker-start={`url(#${markerId})`} marker-end={`url(#${markerId})`} />
      <text x="570" y="104" writing-mode="tb">{heightLabel}</text>
    </svg>
  </div>

  <div class="dimension-row">
    <div class="sketch-block">
      <strong>Frontvisning</strong>
      <svg viewBox="0 0 230 210" role="img" aria-label="Teknisk frontvisning av container">
        <line class="dim-line" x1="42" y1="28" x2="162" y2="28" marker-start={`url(#${markerId})`} marker-end={`url(#${markerId})`} />
        <text x="102" y="20" text-anchor="middle">{widthLabel}</text>
        <g class="container-linework front-drawing">
          {isFlat ? (
            <>
              <rect x="56" y="96" width="104" height="34" rx="2" />
              <rect x="62" y="64" width="18" height="66" />
              <rect x="136" y="64" width="18" height="66" />
              <line x1="62" y1="112" x2="154" y2="112" />
            </>
          ) : (
            <>
              <rect x="52" y="54" width="112" height={isHigh ? "126" : "110"} rx="2" />
              <line x1="108" y1="54" x2="108" y2={isHigh ? "180" : "164"} />
              <rect x="60" y="64" width="40" height={isHigh ? "106" : "90"} />
              <rect x="116" y="64" width="40" height={isHigh ? "106" : "90"} />
              {Array.from({ length: 6 }).map((_, i) => <line x1="60" y1={76 + i * 14} x2="100" y2={76 + i * 14} />)}
              {Array.from({ length: 6 }).map((_, i) => <line x1="116" y1={76 + i * 14} x2="156" y2={76 + i * 14} />)}
              <line class="door-rod" x1="93" y1="66" x2="93" y2={isHigh ? "166" : "150"} />
              <line class="door-rod" x1="123" y1="66" x2="123" y2={isHigh ? "166" : "150"} />
              <circle cx="100" cy={isHigh ? "123" : "113"} r="3" />
              <circle cx="116" cy={isHigh ? "123" : "113"} r="3" />
              {isReefer && <circle class="reefer-fan" cx="108" cy="116" r="24" />}
            </>
          )}
        </g>
      </svg>
    </div>

    <div class="sketch-block">
      <strong>Toppvisning</strong>
      <svg viewBox="0 0 330 210" role="img" aria-label="Teknisk toppvisning av container">
        <g class="container-linework top-drawing">
          {isFlat ? (
            <>
              <rect x="42" y="88" width="240" height="48" rx="2" />
              <rect x="48" y="80" width="22" height="64" />
              <rect x="254" y="80" width="22" height="64" />
              {Array.from({ length: 13 }).map((_, i) => <line x1={82 + i * 13} y1="92" x2={82 + i * 13} y2="132" />)}
            </>
          ) : (
            <>
              <rect x="38" y="58" width="252" height="82" rx="2" />
              <rect x="48" y="68" width="232" height="62" rx="1" />
              {Array.from({ length: 17 }).map((_, i) => <line x1={58 + i * 13} y1="68" x2={58 + i * 13} y2="130" />)}
              <rect x="38" y="58" width="14" height="82" />
              <rect x="276" y="58" width="14" height="82" />
              {isOpen && <rect class="open-top-fill" x="60" y="76" width="196" height="46" rx="2" />}
              {isReefer && <rect class="reefer-top-unit" x="246" y="70" width="30" height="58" rx="2" />}
            </>
          )}
        </g>
        <line class="dim-line" x1="308" y1="58" x2="308" y2="140" marker-start={`url(#${markerId})`} marker-end={`url(#${markerId})`} />
        <text x="322" y="86" writing-mode="tb">{widthLabel}</text>
      </svg>
    </div>
  </div>
</div>
