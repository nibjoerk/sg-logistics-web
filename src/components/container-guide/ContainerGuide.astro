---
import { containerGuideItems } from "../../data/containerGuide";
---

<section class="container-guide" id="containerguide">
  <div class="cg-hero">
    <div>
      <p class="cg-eyebrow">Kjekt å vite · Sjøfrakt</p>
      <h1>Containerguide</h1>
      <p>
        Velg riktig container til ditt gods. Her finner du praktisk oversikt over vanlige
        containertyper, mål, volum og nyttelast. Alle mål er oppgitt metrisk.
      </p>
    </div>

    <div class="cg-tip">
      <span aria-hidden="true">i</span>
      <div>
        <strong>Usikker på hvilken container du skal velge?</strong>
        <p>Kontakt SG Logistics – vi hjelper deg å finne riktig løsning før booking.</p>
      </div>
    </div>
  </div>

  <div class="cg-tabs" role="tablist" aria-label="Containertyper">
    {containerGuideItems.map((item, index) => (
      <button
        class:list={["cg-tab", index === 0 && "is-active"]}
        type="button"
        data-container-tab={item.id}
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
      >
        <img src={item.image} alt="" loading={index === 0 ? "eager" : "lazy"} />
        <span>{item.shortTitle}</span>
        <small>{item.subtitle}</small>
        <em>{item.badge}</em>
      </button>
    ))}
  </div>

  <div class="cg-panels">
    {containerGuideItems.map((item, index) => (
      <article
        class:list={["cg-panel", index === 0 && "is-active"]}
        data-container-panel={item.id}
        hidden={index !== 0}
      >
        <div class="cg-panel-head">
          <div class="cg-panel-copy">
            <h2>{item.title}</h2>
            <span>{item.badge}</span>
            <p>{item.intro}</p>
          </div>
          <img class="cg-hero-image" src={item.image} alt={item.title} loading={index === 0 ? "eager" : "lazy"} />
        </div>

        <div class="cg-detail-grid">
          <section class="cg-drawing">
            <h3>Måltegning</h3>
            <button class="cg-drawing-button" type="button" data-drawing-open={item.drawing} aria-label={`Åpne måltegning for ${item.title}`}>
              <img src={item.drawing} alt={`Måltegning for ${item.title}`} loading={index === 0 ? "eager" : "lazy"} />
            </button>
            <p>Alle mål er oppgitt i millimeter. Mål og vekter kan variere mellom rederier og containerserier.</p>
          </section>

          <section class="cg-specs">
            <h3>Spesifikasjoner</h3>
            <div class="cg-spec-grid">
              {item.specs.map((group) => (
                <div class="cg-table">
                  <strong>{group.title}</strong>
                  {group.rows.map((row) => (
                    <div class="cg-row">
                      <span>{row.label}</span>
                      <b>{row.value}</b>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </section>
        </div>

        <section class="cg-use">
          <h3>Når bør du velge {item.shortTitle}?</h3>
          <div>
            {item.useCases.map((useCase) => (
              <article>
                <span aria-hidden="true">✓</span>
                <div>
                  <strong>{useCase.title}</strong>
                  <p>{useCase.text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      </article>
    ))}
  </div>

  <div class="cg-cta">
    <div>
      <strong>Trenger du hjelp til å velge riktig container?</strong>
      <p>Send oss mål, vekt og beskrivelse av godset – så hjelper vi deg med riktig løsning.</p>
    </div>
    <a href="/#kontakt">Kontakt oss</a>
  </div>

  <dialog class="cg-dialog" data-drawing-dialog>
    <button type="button" data-drawing-close aria-label="Lukk måltegning">×</button>
    <img src="" alt="" data-drawing-image />
  </dialog>
</section>

<script>
  const tabs = Array.from(document.querySelectorAll("[data-container-tab]"));
  const panels = Array.from(document.querySelectorAll("[data-container-panel]"));
  const dialog = document.querySelector("[data-drawing-dialog]");
  const dialogImage = document.querySelector("[data-drawing-image]");
  const closeDialog = document.querySelector("[data-drawing-close]");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const id = tab.getAttribute("data-container-tab");

      tabs.forEach((item) => {
        const active = item === tab;
        item.classList.toggle("is-active", active);
        item.setAttribute("aria-selected", String(active));
      });

      panels.forEach((panel) => {
        const active = panel.getAttribute("data-container-panel") === id;
        panel.classList.toggle("is-active", active);
        panel.toggleAttribute("hidden", !active);
      });
    });
  });

  document.querySelectorAll("[data-drawing-open]").forEach((button) => {
    button.addEventListener("click", () => {
      const src = button.getAttribute("data-drawing-open");
      if (!dialog || !dialogImage || !src) return;
      dialogImage.setAttribute("src", src);
      dialogImage.setAttribute("alt", button.getAttribute("aria-label") || "Måltegning");
      if ("showModal" in dialog) dialog.showModal();
    });
  });

  closeDialog?.addEventListener("click", () => dialog?.close());
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });
</script>

<style>
  .container-guide {
    --cg-green: #064f2f;
    --cg-green-2: #0a6b3f;
    --cg-soft: #eaf5ee;
    --cg-ink: #071f18;
    --cg-muted: #53645e;
    --cg-line: rgba(6, 79, 47, 0.16);
    --cg-shadow: 0 22px 70px rgba(7, 31, 24, 0.08);

    width: min(1220px, calc(100% - 32px));
    margin: 0 auto;
    padding: 56px 0 82px;
    color: var(--cg-ink);
  }

  .cg-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 390px;
    gap: 40px;
    align-items: start;
    margin-bottom: 28px;
  }

  .cg-eyebrow {
    margin: 0 0 12px;
    color: var(--cg-green);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cg-hero h1 {
    margin: 0 0 16px;
    color: var(--cg-ink);
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  .cg-hero p {
    max-width: 690px;
    margin: 0;
    color: var(--cg-muted);
    font-size: 1.08rem;
    line-height: 1.68;
  }

  .cg-tip {
    display: flex;
    gap: 16px;
    padding: 24px;
    border: 1px solid var(--cg-line);
    border-radius: 24px;
    background: linear-gradient(135deg, #fff, #eef7f1);
    box-shadow: 0 16px 46px rgba(7, 31, 24, 0.05);
  }

  .cg-tip span {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 2px solid var(--cg-green);
    border-radius: 999px;
    color: var(--cg-green);
    font-weight: 900;
  }

  .cg-tip strong {
    display: block;
    margin-bottom: 6px;
    font-size: 1rem;
  }

  .cg-tip p {
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .cg-tabs {
    display: grid;
    grid-template-columns: repeat(9, minmax(132px, 1fr));
    gap: 10px;
    margin-bottom: 28px;
    padding: 12px;
    overflow-x: auto;
    border: 1px solid var(--cg-line);
    border-radius: 28px;
    background: #fff;
    box-shadow: var(--cg-shadow);
  }

  .cg-tab {
    min-width: 132px;
    min-height: 178px;
    padding: 10px;
    cursor: pointer;
    text-align: left;
    border: 1px solid rgba(6, 79, 47, 0.13);
    border-radius: 18px;
    background: #fff;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .cg-tab:hover,
  .cg-tab.is-active {
    transform: translateY(-2px);
    border-color: rgba(6, 79, 47, 0.82);
    box-shadow: 0 18px 38px rgba(6, 79, 47, 0.13);
  }

  .cg-tab img {
    width: 100%;
    height: 74px;
    object-fit: contain;
    margin-bottom: 10px;
    filter: drop-shadow(0 10px 12px rgba(7, 31, 24, 0.12));
  }

  .cg-tab span,
  .cg-tab small,
  .cg-tab em {
    display: block;
  }

  .cg-tab span {
    color: var(--cg-ink);
    font-size: 1rem;
    font-weight: 950;
    letter-spacing: -0.04em;
  }

  .cg-tab small {
    margin-top: 3px;
    color: var(--cg-muted);
    font-size: 0.8rem;
    line-height: 1.25;
  }

  .cg-tab em {
    width: fit-content;
    margin-top: 10px;
    padding: 5px 9px;
    border-radius: 9px;
    background: #dff1e5;
    color: var(--cg-green);
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 900;
  }

  .cg-panel {
    padding: 28px;
    border: 1px solid var(--cg-line);
    border-radius: 30px;
    background: #fff;
    box-shadow: var(--cg-shadow);
  }

  .cg-panel[hidden] { display: none; }

  .cg-panel-head {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
    gap: 28px;
    align-items: center;
    margin-bottom: 24px;
  }

  .cg-panel-copy h2 {
    display: inline;
    margin: 0 12px 0 0;
    color: var(--cg-ink);
    font-size: clamp(2rem, 4vw, 3.35rem);
    line-height: 1;
    letter-spacing: -0.065em;
  }

  .cg-panel-copy span {
    display: inline-block;
    margin-top: 8px;
    padding: 8px 13px;
    border-radius: 10px;
    background: #dff1e5;
    color: var(--cg-green);
    font-weight: 950;
  }

  .cg-panel-copy p {
    max-width: 620px;
    margin: 18px 0 0;
    color: var(--cg-muted);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .cg-hero-image {
    width: 100%;
    height: 260px;
    object-fit: contain;
    filter: drop-shadow(0 20px 20px rgba(7, 31, 24, 0.16));
  }

  .cg-detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(430px, 0.92fr);
    gap: 28px;
    align-items: start;
  }

  .cg-drawing h3,
  .cg-specs h3,
  .cg-use h3 {
    margin: 0 0 13px;
    color: var(--cg-green);
    font-size: 0.92rem;
    font-weight: 950;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .cg-drawing-button {
    display: block;
    width: 100%;
    padding: 0;
    cursor: zoom-in;
    overflow: hidden;
    border: 1px solid var(--cg-line);
    border-radius: 20px;
    background: linear-gradient(135deg, #fff, #f8fbf9);
  }

  .cg-drawing-button img {
    display: block;
    width: 100%;
    height: auto;
  }

  .cg-drawing p {
    margin: 12px 0 0;
    color: var(--cg-muted);
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .cg-spec-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .cg-table {
    overflow: hidden;
    border: 1px solid rgba(6, 79, 47, 0.15);
    border-radius: 14px;
    background: #fff;
  }

  .cg-table strong {
    display: block;
    padding: 9px 13px;
    color: var(--cg-green);
    background: linear-gradient(90deg, #dff1e5, #f8fbf9);
    font-size: 0.85rem;
    font-weight: 950;
  }

  .cg-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    border-top: 1px solid rgba(6, 79, 47, 0.1);
  }

  .cg-row span,
  .cg-row b {
    padding: 8px 13px;
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .cg-row span { color: var(--cg-ink); }
  .cg-row b {
    border-left: 1px solid rgba(6, 79, 47, 0.1);
    color: var(--cg-ink);
    font-weight: 950;
  }

  .cg-use {
    margin-top: 24px;
    padding: 22px;
    border: 1px solid var(--cg-line);
    border-radius: 24px;
    background: linear-gradient(135deg, #fff, #f1f8f4);
  }

  .cg-use > div {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .cg-use article {
    display: flex;
    gap: 12px;
    min-width: 0;
  }

  .cg-use article > span {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: #dff1e5;
    color: var(--cg-green);
    font-weight: 950;
  }

  .cg-use strong {
    display: block;
    margin-bottom: 5px;
    font-size: 0.92rem;
  }

  .cg-use p {
    margin: 0;
    color: var(--cg-muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .cg-cta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin-top: 22px;
    padding: 22px 26px;
    border: 1px solid var(--cg-line);
    border-radius: 24px;
    background: linear-gradient(135deg, #fff, #eef7f1);
  }

  .cg-cta strong {
    display: block;
    margin-bottom: 5px;
    font-size: 1.05rem;
  }

  .cg-cta p {
    margin: 0;
    color: var(--cg-muted);
    line-height: 1.5;
  }

  .cg-cta a {
    flex: 0 0 auto;
    display: inline-flex;
    justify-content: center;
    min-width: 156px;
    padding: 13px 20px;
    border-radius: 12px;
    background: var(--cg-green);
    color: #fff;
    font-weight: 950;
    text-decoration: none;
  }

  .cg-dialog {
    width: min(96vw, 1400px);
    max-height: 92vh;
    padding: 18px;
    border: 0;
    border-radius: 24px;
    background: #fff;
  }

  .cg-dialog::backdrop { background: rgba(7, 31, 24, 0.55); }

  .cg-dialog button {
    position: sticky;
    top: 0;
    float: right;
    z-index: 2;
    width: 42px;
    height: 42px;
    border: 0;
    border-radius: 999px;
    background: var(--cg-green);
    color: #fff;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .cg-dialog img {
    display: block;
    width: 100%;
    height: auto;
    clear: both;
  }

  @media (max-width: 1100px) {
    .cg-hero,
    .cg-panel-head,
    .cg-detail-grid {
      grid-template-columns: 1fr;
    }

    .cg-tabs {
      grid-template-columns: repeat(9, minmax(146px, 1fr));
    }

    .cg-hero-image { height: 230px; }
  }

  @media (max-width: 760px) {
    .container-guide {
      width: min(100% - 24px, 1220px);
      padding-top: 34px;
    }

    .cg-hero { gap: 22px; }
    .cg-tip { padding: 20px; }
    .cg-panel { padding: 18px; border-radius: 24px; }
    .cg-hero-image { height: 190px; }
    .cg-spec-grid,
    .cg-use > div { grid-template-columns: 1fr; }
    .cg-row { grid-template-columns: 0.9fr 1.1fr; }
    .cg-cta { flex-direction: column; align-items: stretch; }
    .cg-cta a { width: 100%; }
  }
</style>
