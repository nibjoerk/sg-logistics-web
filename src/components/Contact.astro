---
import "../styles/contact.css";

const contactItems = [
  {
    label: "Adresse",
    value: "Breivika Industriveg 63\n6018 Ålesund",
  },
  {
    label: "Telefon",
    value: "+47 70 17 85 00",
    href: "tel:+4770178500",
  },
  {
    label: "E-post",
    value: "mail@sglogistics.no",
    href: "mailto:mail@sglogistics.no",
  },
  {
    label: "Åpningstid",
    value: "Mandag–Fredag\n08:00–16:00",
  },
];
---

<section id="kontakt" class="contact">
  <div class="container contact-grid">
    <div class="contact-copy">
      <p class="eyebrow">Kontakt</p>

      <h2>Trenger du hjelp med transport eller logistikk?</h2>

      <p class="contact-text">
        Våre medarbeidere hjelper deg gjerne med transport, fortolling og
        komplette logistikkløsninger. Send oss en forespørsel, eller ring oss
        for en rask avklaring.
      </p>

      <div class="contact-actions">
        <a class="button button-primary" href="mailto:mail@sglogistics.no">
          Send e-post
        </a>

        <a class="button button-secondary" href="tel:+4770178500">
          Ring oss
        </a>
      </div>
    </div>

    <aside class="contact-card" aria-label="Kontaktinformasjon for SG Logistics">
      <div class="contact-card-header">
        <p>SG Logistics AS</p>
        <h3>Ålesund</h3>
      </div>

      <div class="contact-list">
        {
          contactItems.map((item) => (
            <div class="contact-item">
              <span>{item.label}</span>

              {
                item.href ? (
                  <a href={item.href}>{item.value}</a>
                ) : (
                  <p>{item.value}</p>
                )
              }
            </div>
          ))
        }
      </div>
    </aside>
  </div>
</section>
