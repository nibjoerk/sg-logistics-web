---
import "../styles/services.css";
import { services } from "../data/services";

const serviceIcons: Record<string, string> = {
  "Bilfrakt": "truck",
  "Flyfrakt": "plane",
  "Sjøfrakt": "ship",
  "Prosjekt": "route",
  "Terminal / Lager": "warehouse",
  "Verdiøkende tjenester": "file",
};
---

<section id="tjenester" class="section section-light services">
  <div class="container">
    <div class="services-top">
      <div class="section-header services-header">
        <p class="eyebrow">Tjenester</p>
        <h2>Transport og logistikk fra A til Å</h2>
        <p class="section-intro">
          SG Logistics tilbyr komplette logistikkløsninger nasjonalt og
          internasjonalt. Vi kombinerer personlig oppfølging med et
          verdensomspennende nettverk.
        </p>
      </div>

      <a href="#kontakt" class="services-note">
        <span>Usikker på hva du trenger?</span>
        <strong>Snakk med oss →</strong>
      </a>
    </div>

    <div class="services-grid">
      {
        services.map((service) => {
          const icon = serviceIcons[service.title] ?? "truck";

          return (
            <article class="service-card">
              <div class="service-icon" aria-hidden="true">
                {icon === "truck" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 17h4V5H2v12h3" />
                    <path d="M14 17h1" />
                    <path d="M19 17h3v-6l-3-4h-5" />
                    <circle cx="7.5" cy="17.5" r="2.5" />
                    <circle cx="17.5" cy="17.5" r="2.5" />
                  </svg>
                )}

                {icon === "plane" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 16 22 3l-6 19-4-8-6 5 2-7z" />
                    <path d="m8 12 8-4-4 6" />
                  </svg>
                )}

                {icon === "ship" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 13h16l-2.5 7h-11z" />
                    <path d="M8 13V7h8v6" />
                    <path d="M4 20c1.5 1 3 1 4.5 0s3-1 4.5 0 3 1 4.5 0 3-1 4.5 0" />
                  </svg>
                )}

                {icon === "route" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="6" cy="6" r="3" />
                    <circle cx="18" cy="18" r="3" />
                    <path d="M9 6h5a4 4 0 0 1 0 8h-2" />
                  </svg>
                )}

                {icon === "warehouse" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 10 12 5l9 5v10H3z" />
                    <path d="M7 20v-7h10v7" />
                    <path d="M9 16h6" />
                  </svg>
                )}

                {icon === "file" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 3h8l4 4v14H6z" />
                    <path d="M14 3v5h4" />
                    <path d="M9 13h6" />
                    <path d="M9 17h6" />
                  </svg>
                )}
              </div>

              <h3>{service.title}</h3>
              <p>{service.text}</p>

              <a href={service.slug} class="service-link">
                Les mer <span aria-hidden="true">→</span>
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
