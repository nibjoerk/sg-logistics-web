---
import { services } from "../data/services";
---

<section id="tjenester" class="section section-light">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Tjenester</p>
      <h2>Transport og logistikk fra A til Å</h2>
      <p class="section-intro">
        SG Logistics tilbyr komplette logistikkløsninger nasjonalt og
        internasjonalt. Vi kombinerer personlig oppfølging med et
        verdensomspennende nettverk.
      </p>
    </div>

    <div class="service-grid">
      {
        services.map((service) => (
          <article class="service-card">
            <div class="service-line"></div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
            <a href={service.slug}>Les mer →</a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 22px;
  }

  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 30px;
  }

  .service-line {
    width: 42px;
    height: 5px;
    background: var(--green);
    border-radius: 999px;
    margin-bottom: 22px;
  }

  .service-card h3 {
    color: var(--black);
    margin-bottom: 12px;
  }

  .service-card p {
    color: var(--text);
    min-height: 82px;
  }

  .service-card a {
    display: inline-flex;
    margin-top: 18px;
    color: var(--green);
    font-weight: 800;
  }
</style>